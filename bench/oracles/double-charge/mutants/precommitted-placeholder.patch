@@ -63,11 +63,23 @@ export class PaymentService {
   async retryPayment(input: RetryPaymentRequest): Promise<PaymentReceipt> {
     assertAmount(input.amount);
     assertOperationToken(input.operationToken);
 
+    const previous = await this.store.get(input.operationToken);
+    if (previous) return previous.receipt;
+
+    await this.store.save({
+      ...input,
+      receipt: {
+        paymentId: `pending-${input.operationToken}`,
+        amount: input.amount,
+        currency: input.currency,
+      },
+    });
     const receipt = await this.gateway.charge({
       amount: input.amount,
       currency: input.currency,
+      idempotencyKey: input.operationToken,
     });
     await this.store.save({ ...input, receipt });
     return receipt;
   }
