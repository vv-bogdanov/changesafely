{
  "schemaVersion": 1,
  "id": "legacy-spaghetti",
  "version": 3,
  "visibleChecks": [{ "argv": ["npm", "test"], "cwd": "." }],
  "preparation": [
    {
      "argv": ["npm", "ci", "--ignore-scripts", "--offline", "--no-audit", "--no-fund"],
      "cwd": ".",
      "network": "disabled"
    }
  ],
  "testPaths": { "prefixes": ["test"], "patterns": ["*.test.js"] },
  "toolchains": [
    { "id": "node", "version": { "argv": ["node", "--version"], "cwd": "." } },
    { "id": "npm", "version": { "argv": ["npm", "--version"], "cwd": "." } }
  ]
}
