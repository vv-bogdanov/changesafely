{
  "apiVersion": "apps/v1",
  "replicas": 3,
  "image": "registry.example/checkout:1.4.2",
  "resources": {
    "requests": { "cpu": "250m", "memory": "256Mi" },
    "limits": { "cpu": "1", "memory": "512Mi" }
  },
  "probes": {
    "readiness": { "path": "/health/ready", "periodSeconds": 5, "failureThreshold": 2 },
    "liveness": { "path": "/health/live", "periodSeconds": 10, "failureThreshold": 3 },
    "startup": { "path": "/health/startup", "periodSeconds": 2, "failureThreshold": 30 }
  },
  "terminationGracePeriodSeconds": 30
}
